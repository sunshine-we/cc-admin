# ========================================
# cc-admin - 通用忽略项
# ========================================

# 操作系统
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.idea/
*.iml
.vscode/
*.sublime-workspace
*.sublime-project

# 日志
*.log
logs/

# 环境变量（仅忽略本地配置，保留示例文件）
.env.local
.env.*.local

# ========================================
# Backend - Java / Spring Boot / Maven
# ========================================

backend/target/
backend/*.jar
backend/*.war
backend/.classpath
backend/.project
backend/.settings/
backend/bin/

# ========================================
# Frontend - Vue / Vite / Node
# ========================================

frontend/node_modules/
frontend/dist/

# ========================================
# 临时文件
# ========================================

*.tmp
*.temp
*.bak
*.orig
